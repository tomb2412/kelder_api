    "# hc_sr04_pi5.py\n",
    "from time import sleep\n",
    "\n",
    "from gpiozero import DistanceSensor\n",
    "\n",
    "# GPIO Pins\n",
    "TRIG = 23\n",
    "ECHO = 24\n",
    "\n",
    "\n",
    "sensor = DistanceSensor(TRIG, ECHO)\n",
    "\n",
    "while True:\n",
    "    print(\"Distance to nearest object is\", sensor.distance, \"m\")\n",
    "    sleep(0.1)"
