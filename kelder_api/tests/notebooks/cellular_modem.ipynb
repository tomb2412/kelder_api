    "import RPi.GPIO as GPIO\n",
    "import time\n",
    "\n",
    "PWRKEY = 26\n",
    "GPIO.setmode(GPIO.BCM)\n",
    "GPIO.setup(PWRKEY, GPIO.OUT)\n",
    "\n",
    "GPIO.output(PWRKEY, GPIO.LOW)\n",
    "time.sleep(1)\n",
    "GPIO.output(PWRKEY, GPIO.HIGH)"
   ]
